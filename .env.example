# ===== HUFS CODE MASTER (Frontend) =====
# Vite 는 VITE_ 접두사가 붙은 변수만 클라이언트로 노출합니다.

# --- SSO ---
# IdP authorize 엔드포인트. 프론트엔드가 사용자를 직접 이 URL 로 보냅니다.
VITE_SSO_AUTHORIZE_URL=https://api.gdghufs.com/v1/sso/authorize
# 백엔드의 codemaster.sso.client-id 와 동일해야 합니다.
VITE_SSO_CLIENT_ID=ps

# --- API ---
# 비워두면 동일 origin 으로 요청합니다 (dev 에선 Vite proxy 가 /api → :8080 으로 포워딩).
# 운영 환경에서 백엔드가 다른 origin 에 있으면 풀 URL 을 넣으세요. 예: https://api-cm.gdghufs.com
VITE_API_BASE_URL=
